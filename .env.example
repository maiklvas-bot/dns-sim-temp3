# Application runtime
NODE_ENV=production
APP_ENV=production
PORT=5000
APP_PORT=5000
PUBLIC_BASE_URL=http://localhost:5000
HEALTHCHECK_URL=http://127.0.0.1:5000/api/health

# Security
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret-minimum-32-chars
HTTPS=false
SYNC_STAFF_FROM_ENV=false

# Backups
BACKUP_ROOT=/backups/site
SITE_ROOT=/opt/site-prod

# Administrator login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password-to-strong-random
ADMIN_DISPLAY_NAME="Главный администратор"

# Evaluator login
EVALUATOR_USERNAME=evaluator
EVALUATOR_PASSWORD=change-me-evaluator-password-to-strong-random
EVALUATOR_DISPLAY_NAME="Оценщик"

# Обратная связь (форма «Обратная связь»). Generic SMTP — заполните под свой
# почтовый сервер. Пока переменные не заданы, форма отвечает «отправка не настроена».
FEEDBACK_SMTP_HOST=
FEEDBACK_SMTP_PORT=587
FEEDBACK_SMTP_SECURE=false
FEEDBACK_SMTP_USER=
FEEDBACK_SMTP_PASS=
# Адрес-отправитель (обязателен для включения отправки), напр. "DNS SimCenter <noreply@dns-shop.ru>"
FEEDBACK_FROM=
# Получатели через запятую; если пусто — используются адреса разработчиков по умолчанию
FEEDBACK_RECIPIENTS=
